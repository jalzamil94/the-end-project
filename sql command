DROP TABLE IF EXISTS evaluation;
DROP TABLE IF EXISTS complaint;

-- 2. الآن يمكننا حذف جدول الطلبات بأمان
DROP TABLE IF EXISTS servicerequest;
DROP TABLE IF EXISTS ServiceRequest;

-- 3. إنشاء جدول الطلبات بالهيكلة الصحيحة
CREATE TABLE ServiceRequest (
    requestId INT AUTO_INCREMENT PRIMARY KEY,
    createdAt TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    status ENUM('Pending', 'Accepted', 'Completed', 'Canceled') DEFAULT 'Pending',
    clientId INT,
    technicianId INT NULL,
    serviceId INT,
    locationId INT,
    FOREIGN KEY (clientId) REFERENCES User(UserID) ON DELETE CASCADE,
    FOREIGN KEY (technicianId) REFERENCES User(UserID) ON DELETE SET NULL,
    FOREIGN KEY (serviceId) REFERENCES ServiceType(serviceId) ON DELETE CASCADE,
    FOREIGN KEY (locationId) REFERENCES Location(locationId) ON DELETE SET NULL
);

-- 4. إعادة إنشاء جدول الشكاوى
CREATE TABLE Complaint (
    complaintId INT AUTO_INCREMENT PRIMARY KEY,
    description TEXT NOT NULL,
    createdAt TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    status ENUM('Open', 'Resolved', 'Closed') DEFAULT 'Open',
    requestId INT,
    FOREIGN KEY (requestId) REFERENCES ServiceRequest(requestId) ON DELETE CASCADE
);

-- 5. إعادة إنشاء جدول التقييمات
CREATE TABLE Evaluation (
    evaluationId INT AUTO_INCREMENT PRIMARY KEY,
    serviceRating INT CHECK (serviceRating BETWEEN 1 AND 5),
    technicianRating INT CHECK (technicianRating BETWEEN 1 AND 5),
    evaluatorUserId INT,
    requestId INT,
    FOREIGN KEY (evaluatorUserId) REFERENCES User(UserID) ON DELETE CASCADE,
    FOREIGN KEY (requestId) REFERENCES ServiceRequest(requestId) ON DELETE CASCADE
);

